pipeline {
    agent any

    stages {
        stage('Build'){
            steps {
                echo 'this is first declaration of build stage'
            }
        }
        stage('docker build'){
            steps {
                echo 'here iam building the docker image'
            }
        }
        stage('Test'){
            steps {
                echo 'this is first declaration of test stage'
            }
        }
    }
}